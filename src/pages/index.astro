<script>
  // Savings calculator
  const monthlyVal = document.getElementById('monthly-val');
  const rangeMonthly = document.getElementById('range-monthly');
  const numberMonthly = document.getElementById('number-monthly');
  const fiveSpend = document.getElementById('five-spend');
  const tenSpend = document.getElementById('ten-spend');
  const tenSave = document.getElementById('ten-save');
  const presetClassic = document.getElementById('preset-classic');

  function fmt(n) {
    return Math.max(0, Math.round(n)).toLocaleString('fr-FR') + ' €';
  }

  function updateCalc(v) {
    const val = Math.max(0, Math.min(500, Number(v) || 0));
    monthlyVal.textContent = val;
    rangeMonthly.value = Math.min(val, 80);
    numberMonthly.value = val;
    fiveSpend.textContent = fmt(val * 60);
    tenSpend.textContent = fmt(val * 120);
    tenSave.textContent = fmt(val * 120 - 499);
  }

  rangeMonthly.addEventListener('input', e => updateCalc(e.target.value));
  numberMonthly.addEventListener('input', e => updateCalc(e.target.value));
  presetClassic.addEventListener('click', () => updateCalc(25));

  // FAQ accordion
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const answer = btn.nextElementSibling;
      const sign = btn.querySelector('.faq-sign');
      const isOpen = answer.style.display !== 'none';

      document.querySelectorAll('.faq-answer').forEach(a => (a.style.display = 'none'));
      document.querySelectorAll('.faq-sign').forEach(s => (s.textContent = '+'));

      if (!isOpen) {
        answer.style.display = 'block';
        sign.textContent = '–';
      }
    });
  });

  // Hero form toggle (pricing card)
  const heroToggleBtn = document.getElementById('hero-toggle-btn');
  const heroFormExpand = document.getElementById('hero-form-expand');
  const heroThankYou = document.getElementById('hero-thank-you');
  const heroFormContent = document.getElementById('hero-form-content');
  const heroEmailForm = document.getElementById('hero-email-form');
  const heroClosedText = document.getElementById('hero-form-closed-text');
  let heroOpen = false;

  heroToggleBtn.addEventListener('click', () => {
    heroOpen = !heroOpen;
    if (heroOpen) {
      heroFormExpand.style.display = 'block';
      heroFormExpand.style.animation = 'heroReveal .42s cubic-bezier(.2,.75,.25,1)';
      heroClosedText.style.display = 'none';
    } else {
      heroFormExpand.style.display = 'none';
      heroClosedText.style.display = 'block';
    }
  });

  heroEmailForm.addEventListener('submit', e => {
    e.preventDefault();
    heroFormContent.style.display = 'none';
    heroThankYou.style.display = 'block';
  });

  // Final CTA form
  const finalEmailForm = document.getElementById('final-email-form');
  const finalThankYou = document.getElementById('final-thank-you');
  const finalFormContent = document.getElementById('final-form-content');

  finalEmailForm.addEventListener('submit', e => {
    e.preventDefault();
    finalFormContent.style.display = 'none';
    finalThankYou.style.display = 'block';
  });

  // Scroll reveal
  const reveals = document.querySelectorAll('[data-reveal]');
  reveals.forEach(el => {
    el.style.opacity = '0';
    el.style.transform = 'translateY(28px)';
    el.style.transition = 'opacity .8s ease, transform .8s cubic-bezier(.2,.75,.25,1)';
    const d = el.getAttribute('data-reveal-delay');
    if (d) el.style.transitionDelay = d + 'ms';
  });
  const io = new IntersectionObserver(ents => {
    ents.forEach(en => {
      if (en.isIntersecting) {
        en.target.style.opacity = '1';
        en.target.style.transform = 'none';
        io.unobserve(en.target);
      }
    });
  }, { threshold: 0.12 });
  reveals.forEach(el => io.observe(el));
</script>
