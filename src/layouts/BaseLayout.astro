---
import { SEO } from 'astro-seo';
import { t, tObj, getLang } from '../utils/i18n';
import { generateSoftwareJsonLd, generateFaqJsonLd } from '../utils/seo';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import StickyCtaBar from '../components/StickyCtaBar.astro';
import '../styles/global.css';
import '../styles/animations.css';

const lang = getLang(Astro.url);
const meta = tObj(lang, 'meta') as { title: string; description: string; ogTitle: string; ogDescription: string };
const faqItems = (tObj(lang, 'faq.items') as { q: string; a: string }[]) || [];
const altLang = lang === 'fr' ? 'en' : 'fr';
const altPath = lang === 'fr' ? '/en/' : '/';
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate" hreflang={altLang} href={`https://osteolocal.fr${altPath}`} />
  <link rel="alternate" hreflang={lang} href={`https://osteolocal.fr${lang === 'fr' ? '/' : '/en/'}`} />
  <link rel="canonical" href={`https://osteolocal.fr${lang === 'fr' ? '/' : '/en/'}`} />
  <SEO
    title={meta.title}
    description={meta.description}
    openGraph={{
      basic: {
        title: meta.ogTitle,
        type: 'website',
        image: `https://osteolocal.fr/og-image-${lang}.jpg`,
      },
      optional: {
        description: meta.ogDescription,
        locale: lang === 'fr' ? 'fr_FR' : 'en_US',
        siteName: 'OsteoLocal',
      },
    }}
    twitter={{
      card: 'summary_large_image',
      title: meta.ogTitle,
      description: meta.ogDescription,
      image: `https://osteolocal.fr/og-image-${lang}.jpg`,
    }}
  />
  <script type="application/ld+json" set:html={generateSoftwareJsonLd(lang)} />
  <script type="application/ld+json" set:html={generateFaqJsonLd(faqItems)} />
</head>
<body class="overflow-x-hidden">
  <Nav lang={lang} />
  <main>
    <slot />
  </main>
  <Footer lang={lang} />
  <StickyCtaBar lang={lang} />

  <!-- Scroll animation observer -->
  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );

    document.querySelectorAll('[data-animate]').forEach((el) => {
      observer.observe(el);
    });
  </script>

  <!-- LemonSqueezy checkout overlay -->
  <script src="https://assets.lemonsqueezy.com/lemon.js" defer></script>
</body>
</html>
