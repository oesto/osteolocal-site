---
import { t, localizedPath } from '../utils/i18n';

interface Props {
  lang: 'fr' | 'en';
}

const { lang } = Astro.props;
const altLang = lang === 'fr' ? 'en' : 'fr';
const altPath = lang === 'fr' ? '/en/' : '/';
const altLabel = lang === 'fr' ? 'EN' : 'FR';
---

<nav class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" id="main-nav" style="height: 72px;">
  <div class="absolute inset-0 bg-white/80 backdrop-blur-xl border-b transition-opacity duration-300" style="border-color: rgba(0,0,0,0.06);" id="nav-bg"></div>
  <div class="relative max-w-[1200px] mx-auto px-6 h-full flex items-center justify-between">
    <!-- Logo -->
    <a href={localizedPath(lang, '/')} class="flex items-center gap-2.5 font-bold text-lg" style="font-family: var(--font-display); color: var(--color-primary-800);">
      <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, var(--color-primary-600), var(--color-primary-700));">
        <svg width="18" height="18" viewBox="0 0 28 28" fill="none">
          <circle cx="14" cy="14" r="12" stroke="#fff" stroke-width="2"/>
          <path d="M10 18 C10 13, 14 9, 14 9 C14 9, 18 13, 18 18" stroke="#fff" stroke-width="2" stroke-linecap="round" fill="none"/>
          <circle cx="14" cy="10" r="1.5" fill="#fff"/>
        </svg>
      </div>
      OsteoLocal
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-1">
      <a href={`${localizedPath(lang, '/')}#fonctionnalites`} class="px-4 py-2 rounded-lg text-[13px] font-medium transition-colors hover:bg-black/[0.03]" style="color: var(--color-text-body);">{t(lang, 'nav.features')}</a>
      <a href={`${localizedPath(lang, '/')}#tarifs`} class="px-4 py-2 rounded-lg text-[13px] font-medium transition-colors hover:bg-black/[0.03]" style="color: var(--color-text-body);">{t(lang, 'nav.pricing')}</a>
      <a href={`${localizedPath(lang, '/')}#securite`} class="px-4 py-2 rounded-lg text-[13px] font-medium transition-colors hover:bg-black/[0.03]" style="color: var(--color-text-body);">{t(lang, 'nav.security')}</a>
      <a href={`${localizedPath(lang, '/')}#faq`} class="px-4 py-2 rounded-lg text-[13px] font-medium transition-colors hover:bg-black/[0.03]" style="color: var(--color-text-body);">{t(lang, 'nav.faq')}</a>
      <div class="w-px h-5 mx-2" style="background: var(--color-warm-200);"></div>
      <a href={altPath} class="px-3 py-1.5 rounded-md text-xs font-semibold transition-colors hover:bg-black/[0.03]" style="color: var(--color-text-muted);">{altLabel}</a>
      <a href="#tarifs" class="btn-primary ml-3 px-5 py-2.5 rounded-xl text-[13px] font-semibold">
        {t(lang, 'nav.cta')}
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button id="mobile-menu-btn" class="md:hidden p-2 -mr-2 rounded-lg hover:bg-black/[0.03] transition-colors" aria-label="Menu">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="4" y1="7" x2="20" y2="7" />
        <line x1="4" y1="12" x2="20" y2="12" />
        <line x1="4" y1="17" x2="20" y2="17" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden bg-white/95 backdrop-blur-xl border-b shadow-elevated" style="border-color: rgba(0,0,0,0.06);">
    <div class="px-6 py-5 flex flex-col gap-1">
      <a href={`${localizedPath(lang, '/')}#fonctionnalites`} class="px-4 py-3 rounded-lg text-[15px] font-medium hover:bg-black/[0.03] transition-colors" style="color: var(--color-text-body);">{t(lang, 'nav.features')}</a>
      <a href={`${localizedPath(lang, '/')}#tarifs`} class="px-4 py-3 rounded-lg text-[15px] font-medium hover:bg-black/[0.03] transition-colors" style="color: var(--color-text-body);">{t(lang, 'nav.pricing')}</a>
      <a href={`${localizedPath(lang, '/')}#securite`} class="px-4 py-3 rounded-lg text-[15px] font-medium hover:bg-black/[0.03] transition-colors" style="color: var(--color-text-body);">{t(lang, 'nav.security')}</a>
      <a href={`${localizedPath(lang, '/')}#faq`} class="px-4 py-3 rounded-lg text-[15px] font-medium hover:bg-black/[0.03] transition-colors" style="color: var(--color-text-body);">{t(lang, 'nav.faq')}</a>
      <div class="h-px my-2" style="background: var(--color-warm-200);"></div>
      <div class="flex items-center gap-3 px-4">
        <a href={altPath} class="px-4 py-2.5 rounded-lg text-sm font-semibold border transition-colors" style="color: var(--color-text-muted); border-color: var(--color-warm-200);">{altLabel}</a>
        <a href="#tarifs" class="btn-primary flex-1 text-center px-5 py-2.5 rounded-xl text-sm font-semibold">
          {t(lang, 'nav.cta')}
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  menu?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => menu?.classList.add('hidden'))
  );
</script>
