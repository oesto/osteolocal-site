---
import { t, tObj } from '../utils/i18n';

interface Props {
  lang: 'fr' | 'en';
}

const { lang } = Astro.props;
const columns = tObj(lang, 'footer.columns') as Record<string, { title: string; links: { label: string; href: string }[] }>;
const year = new Date().getFullYear();
const copyright = t(lang, 'footer.copyright').replace('{year}', String(year));
---

<footer style="background: var(--color-dark-950); color: var(--color-text-on-dark);">
  <div class="max-w-[1200px] mx-auto px-6 pt-20 pb-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center gap-2.5 font-bold text-lg mb-5" style="font-family: var(--font-display); color: var(--color-primary-400);">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: rgba(13,148,136,0.15);">
            <svg width="18" height="18" viewBox="0 0 28 28" fill="none">
              <circle cx="14" cy="14" r="12" stroke="var(--color-primary-400)" stroke-width="2"/>
              <path d="M10 18 C10 13, 14 9, 14 9 C14 9, 18 13, 18 18" stroke="var(--color-primary-400)" stroke-width="2" stroke-linecap="round" fill="none"/>
              <circle cx="14" cy="10" r="1.5" fill="var(--color-primary-400)"/>
            </svg>
          </div>
          OsteoLocal
        </a>
        <p class="text-[13px] leading-[1.75]" style="color: #71717a;">
          {t(lang, 'footer.tagline')}
        </p>
      </div>

      <!-- Columns -->
      {Object.values(columns).map((col) => (
        <div>
          <h4 class="text-[11px] font-bold mb-5 uppercase tracking-[0.12em]" style="color: #52525b; font-family: var(--font-body);">{col.title}</h4>
          <ul class="space-y-3.5">
            {col.links.map((link) => (
              <li>
                <a href={link.href} class="text-[13px] transition-colors hover:text-white" style="color: #a1a1aa;">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="border-t pt-8 flex flex-col md:flex-row items-center justify-between gap-4" style="border-color: rgba(255,255,255,0.06);">
      <p class="text-[12px]" style="color: #52525b;">{copyright}</p>
    </div>
  </div>
</footer>
