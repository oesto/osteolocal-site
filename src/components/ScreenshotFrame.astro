---
interface Props {
  alt?: string;
  class?: string;
}

const { alt = 'OsteoLocal screenshot', class: className = '' } = Astro.props;
---

<div class:list={['relative rounded-xl overflow-hidden', className]} style="background: var(--color-warm-100);">
  <!-- macOS-style title bar -->
  <div class="flex items-center gap-2 px-4 py-2.5" style="background: linear-gradient(to bottom, var(--color-warm-100), var(--color-warm-50)); border-bottom: 1px solid var(--color-warm-200);">
    <div class="flex gap-1.5">
      <div class="w-2.5 h-2.5 rounded-full" style="background: #FF5F57;"></div>
      <div class="w-2.5 h-2.5 rounded-full" style="background: #FEBC2E;"></div>
      <div class="w-2.5 h-2.5 rounded-full" style="background: #28C840;"></div>
    </div>
    <div class="flex-1 mx-8">
      <div class="max-w-[180px] mx-auto h-5 rounded-md flex items-center justify-center" style="background: var(--color-warm-50); border: 1px solid var(--color-warm-200);">
        <span class="text-[10px] font-medium" style="color: var(--color-text-muted);">OsteoLocal</span>
      </div>
    </div>
    <div class="w-[42px]"></div>
  </div>
  <!-- Content -->
  <div style="background: #fff;">
    <slot>
      <div class="aspect-video flex items-center justify-center" style="background: linear-gradient(135deg, var(--color-warm-50) 0%, #fff 100%);">
        <p class="text-sm" style="color: var(--color-text-muted);">{alt}</p>
      </div>
    </slot>
  </div>
</div>
