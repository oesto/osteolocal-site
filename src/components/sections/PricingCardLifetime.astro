---
import { t, tArray } from '../../utils/i18n';
import { Icon } from 'astro-icon/components';

interface Props {
  lang: 'fr' | 'en';
}

const { lang } = Astro.props;
const features = tArray(lang, 'pricing.lifetime.features');
---

<div class="relative rounded-3xl p-9 md:p-10 h-full flex flex-col overflow-hidden" style="background: #fff; border: 2px solid var(--color-primary-500); box-shadow: 0 0 0 4px rgba(13,148,136,0.06), 0 20px 60px rgba(13,148,136,0.12);">
  <!-- Gradient top bar -->
  <div class="absolute top-0 left-0 right-0 h-1" style="background: linear-gradient(90deg, var(--color-primary-400), var(--color-primary-600));"></div>

  <!-- Recommended badge -->
  <div class="absolute -top-px left-1/2 -translate-x-1/2">
    <div class="px-5 py-1.5 rounded-b-xl text-xs font-bold uppercase tracking-wider text-white" style="background: linear-gradient(135deg, var(--color-primary-600), var(--color-primary-700));">
      {t(lang, 'pricing.lifetime.badge')}
    </div>
  </div>

  <div class="text-center mb-8 pt-4">
    <h3 class="text-xl font-bold mb-1" style="font-family: var(--font-display); color: var(--color-text-heading);">
      {t(lang, 'pricing.lifetime.title')}
    </h3>
    <p class="text-sm" style="color: var(--color-text-muted);">{t(lang, 'pricing.lifetime.subtitle')}</p>
  </div>

  <!-- Price — the star -->
  <div class="text-center mb-8">
    <div class="flex items-baseline justify-center gap-1">
      <span class="text-[64px] font-bold leading-none" style="font-family: var(--font-display); color: var(--color-text-heading); letter-spacing: -0.04em;">
        {t(lang, 'pricing.lifetime.price')}
      </span>
      <span class="text-2xl font-semibold" style="color: var(--color-text-muted);">€</span>
    </div>
    <p class="text-xs mt-2 font-medium" style="color: var(--color-primary-600);">
      {lang === 'fr' ? 'Paiement unique — le logiciel est à vous' : 'One-time payment — the software is yours'}
    </p>
  </div>

  <!-- Features -->
  <ul class="space-y-3.5 mb-9 flex-1">
    {features.map((feature) => (
      <li class="flex items-start gap-3 text-[14px] leading-relaxed" style="color: var(--color-text-body);">
        <span class="mt-0.5 w-5 h-5 rounded-full flex items-center justify-center shrink-0" style="background: var(--color-primary-50);">
          <Icon name="lucide:check" class="w-3 h-3" style="color: var(--color-primary-600);" />
        </span>
        {feature}
      </li>
    ))}
  </ul>

  <!-- CTA -->
  <a href="https://osteolocal.lemonsqueezy.com/checkout/buy/lifetime" class="btn-primary lemonsqueezy-button flex items-center justify-center gap-2 w-full px-6 py-4 rounded-2xl text-base font-semibold">
    {t(lang, 'pricing.lifetime.cta')}
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <path d="M3 8h10M9 4l4 4-4 4" />
    </svg>
  </a>

  <p class="text-[11px] text-center mt-4 leading-relaxed" style="color: var(--color-text-muted);">
    {t(lang, 'pricing.lifetime.footnote')}
  </p>
</div>
