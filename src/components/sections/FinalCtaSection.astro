---
import { t, tArray } from '../../utils/i18n';
import { Icon } from 'astro-icon/components';

interface Props {
  lang: 'fr' | 'en';
}

const { lang } = Astro.props;
const reassurance = tArray(lang, 'finalCta.reassurance');
const icons = ['lucide:gift', 'lucide:arrow-right-left', 'lucide:wifi-off', 'lucide:headphones', 'lucide:heart'];
---

<section class="relative py-24 md:py-32 overflow-hidden" style="background: linear-gradient(160deg, #f0fdfa 0%, #e6f7f4 30%, var(--color-primary-50) 60%, var(--color-warm-50) 100%);">
  <!-- Decorative elements -->
  <div class="absolute top-[20%] right-[-5%] w-[400px] h-[400px] rounded-full opacity-[0.08]" style="background: radial-gradient(circle, var(--color-primary-400), transparent 70%);"></div>
  <div class="absolute bottom-[10%] left-[-5%] w-[300px] h-[300px] rounded-full opacity-[0.06]" style="background: radial-gradient(circle, var(--color-primary-500), transparent 70%);"></div>

  <div class="relative z-10 max-w-[800px] mx-auto px-6 text-center">
    <div data-animate="fade-up">
      <div class="section-divider"></div>
      <h2 class="text-[30px] md:text-[48px] font-bold leading-[1.08] mb-5" style="font-family: var(--font-display); color: var(--color-text-heading);">
        {t(lang, 'finalCta.title')}
        <span style="color: var(--color-primary-600);"> {t(lang, 'finalCta.titleAccent')}</span>
      </h2>

      <p class="text-lg md:text-xl mb-10 leading-relaxed" style="color: var(--color-text-body);">
        {t(lang, 'finalCta.subtitle')}
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-14">
        <a href="#tarifs" class="btn-primary inline-flex items-center gap-3 px-10 py-5 rounded-2xl text-lg font-semibold">
          {t(lang, 'finalCta.cta')}
          <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M3 8h10M9 4l4 4-4 4" />
          </svg>
        </a>
        <a href="mailto:contact@osteolocal.fr" class="inline-flex items-center gap-2 px-6 py-5 rounded-2xl text-sm font-semibold transition-all hover:bg-white/50" style="color: var(--color-primary-700);">
          {t(lang, 'finalCta.ctaSecondary')}
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M3 8h10M9 4l4 4-4 4" />
          </svg>
        </a>
      </div>

      <!-- Reassurance -->
      <div class="inline-grid grid-cols-1 sm:grid-cols-2 gap-x-10 gap-y-4 text-left">
        {reassurance.map((item, i) => (
          <div class="flex items-center gap-3 text-[14px]" style="color: var(--color-text-body);">
            <div class="w-8 h-8 rounded-xl flex items-center justify-center shrink-0" style="background: rgba(13,148,136,0.08);">
              <Icon name={icons[i] || 'lucide:check'} class="w-4 h-4" style="color: var(--color-primary-600);" />
            </div>
            {item}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
