---
import { t, tObj } from '../../utils/i18n';

interface Props {
  lang: 'fr' | 'en';
}

const { lang } = Astro.props;
const items = (tObj(lang, 'faq.items') as { q: string; a: string }[]) || [];
---

<section id="faq" class="py-24 md:py-32 section-light">
  <div class="max-w-[720px] mx-auto px-6">
    <div class="text-center mb-14">
      <div class="section-divider"></div>
      <h2 class="text-[28px] md:text-[44px] font-bold leading-[1.08]" style="font-family: var(--font-display); color: var(--color-text-heading);">
        {t(lang, 'faq.title')}
        <span style="color: var(--color-primary-600);"> {t(lang, 'faq.titleAccent')}</span>
      </h2>
    </div>

    <div class="space-y-3" data-animate="fade-up">
      {items.map((item) => (
        <details class="group rounded-2xl overflow-hidden shadow-card transition-all hover:shadow-card-hover" style="background: #fff; border: 1px solid var(--color-warm-200);">
          <summary class="flex items-center justify-between gap-4 px-7 py-6 cursor-pointer list-none select-none">
            <span class="text-[15px] font-semibold leading-snug" style="color: var(--color-text-heading);">{item.q}</span>
            <span class="w-7 h-7 rounded-full flex items-center justify-center shrink-0 transition-colors group-open:bg-primary-50" style="background: var(--color-warm-50);">
              <svg class="w-4 h-4 transition-transform duration-300 group-open:rotate-45" viewBox="0 0 20 20" fill="none" stroke="var(--color-primary-600)" stroke-width="2" stroke-linecap="round">
                <path d="M10 4v12M4 10h12" />
              </svg>
            </span>
          </summary>
          <div class="faq-content">
            <div>
              <p class="px-7 pb-6 text-[15px] leading-[1.8]" style="color: var(--color-text-body);">
                {item.a}
              </p>
            </div>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
