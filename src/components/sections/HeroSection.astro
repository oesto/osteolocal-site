---
import { t, tArray } from '../../utils/i18n';
import ScreenshotFrame from '../ScreenshotFrame.astro';

interface Props {
  lang: 'fr' | 'en';
}

const { lang } = Astro.props;
const proofItems = tArray(lang, 'hero.proof');
---

<section class="relative min-h-screen flex flex-col justify-center grain-overlay overflow-hidden" style="background: linear-gradient(175deg, #F9F8F6 0%, #f0fdfa 40%, #e6f7f4 70%, #F9F8F6 100%);">
  <!-- Decorative blobs -->
  <div class="absolute top-[-10%] right-[-5%] w-[600px] h-[600px] rounded-full opacity-[0.07]" style="background: radial-gradient(circle, var(--color-primary-400), transparent 70%);"></div>
  <div class="absolute bottom-[10%] left-[-10%] w-[500px] h-[500px] rounded-full opacity-[0.05]" style="background: radial-gradient(circle, var(--color-primary-500), transparent 70%);"></div>

  <div class="relative z-10 max-w-[1200px] mx-auto px-6 pt-32 md:pt-40 pb-8 md:pb-12">
    <div class="max-w-[780px] mx-auto text-center">
      <!-- Eyebrow -->
      <div data-animate="fade-up" class="hero-headline inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold tracking-wide uppercase mb-8" style="background: rgba(13,148,136,0.08); color: var(--color-primary-700); border: 1px solid rgba(13,148,136,0.15);">
        <span class="w-1.5 h-1.5 rounded-full" style="background: var(--color-primary-500);"></span>
        {lang === 'fr' ? 'Logiciel de gestion pour ostéopathes' : 'Practice management for osteopaths'}
      </div>

      <!-- Headline -->
      <h1
        data-animate="fade-up"
        class="hero-headline text-[38px] md:text-[60px] lg:text-[66px] font-bold leading-[1.06] mb-7"
        style="font-family: var(--font-display); color: var(--color-text-heading);"
      >
        {t(lang, 'hero.title')}<br />
        <span class="relative inline-block" style="color: var(--color-primary-700);">
          {t(lang, 'hero.titleAccent')}
          <span class="absolute bottom-1 left-0 right-0 h-3 -z-10 opacity-20 rounded-sm" style="background: var(--color-primary-400);"></span>
        </span>
      </h1>

      <!-- Subtitle -->
      <p
        data-animate="fade-up"
        class="hero-subtitle text-lg md:text-[21px] leading-[1.7] mb-10 max-w-[640px] mx-auto"
        style="color: var(--color-text-body); letter-spacing: -0.011em;"
      >
        {t(lang, 'hero.subtitle')}
      </p>

      <!-- CTAs -->
      <div data-animate="fade-up" class="hero-ctas flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
        <a href="#tarifs" class="btn-primary inline-flex items-center gap-3 px-8 py-4 rounded-2xl text-base font-semibold">
          {t(lang, 'hero.cta')}
          <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M3 8h10M9 4l4 4-4 4" />
          </svg>
        </a>
        <a href="#fonctionnalites" class="inline-flex items-center gap-2 px-6 py-4 rounded-2xl text-sm font-semibold transition-all hover:bg-white/60" style="color: var(--color-primary-700);">
          {t(lang, 'hero.ctaSecondary')}
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M3 8h10M9 4l4 4-4 4" />
          </svg>
        </a>
      </div>

      <!-- Social proof bar -->
      <div data-animate="fade-up" class="hero-proof flex flex-wrap justify-center gap-x-8 gap-y-3">
        {proofItems.map((item) => (
          <div class="flex items-center gap-2.5 text-[13px] font-medium" style="color: var(--color-text-muted);">
            <span class="flex items-center justify-center w-5 h-5 rounded-full" style="background: var(--color-primary-100);">
              <svg width="11" height="11" viewBox="0 0 16 16" fill="none">
                <path d="M4 8l3 3 5-5" stroke="var(--color-primary-600)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            {item}
          </div>
        ))}
      </div>
    </div>

    <!-- Screenshot — THE hero visual -->
    <div data-animate="scale-up" class="hero-screenshot mt-16 md:mt-20 max-w-[1100px] mx-auto" style="perspective: 1200px;">
      <div class="relative" style="transform: rotateX(2deg) rotateY(0deg);">
        <!-- Glow behind -->
        <div class="absolute inset-x-[10%] -bottom-8 h-32 rounded-full blur-3xl opacity-20" style="background: var(--color-primary-500);"></div>
        <div class="shadow-screenshot rounded-2xl overflow-hidden" style="border: 1px solid rgba(0,0,0,0.08);">
          <ScreenshotFrame alt="OsteoLocal Dashboard">
            <img src="/screenshots/dashboard.png" alt="OsteoLocal — Tableau de bord" width="1504" height="780" loading="eager" class="w-full h-auto" />
          </ScreenshotFrame>
        </div>
      </div>
    </div>
  </div>

  <!-- Soft fade to next section -->
  <div class="h-24 md:h-32" style="background: linear-gradient(to bottom, transparent, #fff);"></div>
</section>
