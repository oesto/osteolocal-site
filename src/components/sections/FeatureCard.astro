---
import { Icon } from 'astro-icon/components';
import ScreenshotFrame from '../ScreenshotFrame.astro';

interface Props {
  icon: string;
  title: string;
  description: string;
  points: string[];
  screenshot?: string;
}

const { icon, title, description, points, screenshot } = Astro.props;
---

<div class="rounded-2xl overflow-hidden h-full transition-shadow duration-300 hover:shadow-lg" style="background: #fff; border: 1px solid var(--color-warm-200);">
  {screenshot && (
    <div class="p-4 pb-0">
      <ScreenshotFrame alt={title}>
        <img src={screenshot} alt={title} loading="lazy" class="w-full h-auto" />
      </ScreenshotFrame>
    </div>
  )}

  <div class="p-8">
    <div class="flex items-start gap-4 mb-4">
      <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background: var(--color-primary-50);">
        <Icon name={icon} class="w-5 h-5" style="color: var(--color-primary-600);" />
      </div>
      <div>
        <h3 class="text-lg font-semibold mb-2" style="font-family: var(--font-body); color: var(--color-text-heading);">
          {title}
        </h3>
        <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">
          {description}
        </p>
      </div>
    </div>

    <ul class="space-y-2 mt-4">
      {points.map((point) => (
        <li class="flex items-start gap-2 text-sm" style="color: var(--color-text-body);">
          <svg class="w-4 h-4 shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none">
            <path d="M5 8l2 2 4-4" stroke="var(--color-primary-500)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          {point}
        </li>
      ))}
    </ul>
  </div>
</div>
