---
import { t, tObj } from '../../utils/i18n';
import { Icon } from 'astro-icon/components';
import ScreenshotFrame from '../ScreenshotFrame.astro';

interface Props {
  lang: 'fr' | 'en';
}

const { lang } = Astro.props;
const cards = (tObj(lang, 'features.cards') as { icon: string; title: string; description: string; points: string[] }[]) || [];
const alsoItems = (tObj(lang, 'features.also') as { icon: string; text: string }[]) || [];

const screenshots: Record<number, string> = {
  0: '/screenshots/patient-profile.png',
  1: '/screenshots/calendar.png',
  2: '/screenshots/dashboard.png',
  3: '/screenshots/invoicing.png',
  4: '/screenshots/statistics.png',
  5: '/screenshots/documents.png',
  6: '/screenshots/settings.png',
};
---

<section id="fonctionnalites" class="py-24 md:py-32 section-warm">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="text-center max-w-3xl mx-auto mb-20">
      <div class="section-divider"></div>
      <h2 class="text-[28px] md:text-[44px] font-bold leading-[1.08] mb-5" style="font-family: var(--font-display); color: var(--color-text-heading);">
        {t(lang, 'features.title')}
        <span style="color: var(--color-primary-600);"> {t(lang, 'features.titleAccent')}</span>
      </h2>
      <p class="text-lg leading-relaxed" style="color: var(--color-text-muted);">
        {t(lang, 'features.subtitle')}
      </p>
    </div>

    <!-- Alternating feature rows -->
    <div class="space-y-20 md:space-y-28 mb-24">
      {cards.map((card, i) => {
        const isReversed = i % 2 === 1;
        const screenshot = screenshots[i];
        return (
          <div class={`grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center ${isReversed ? 'md:[direction:rtl]' : ''}`}>
            <!-- Text side -->
            <div data-animate={isReversed ? 'slide-right' : 'slide-left'} class={isReversed ? 'md:[direction:ltr]' : ''}>
              <div class="flex items-center gap-3 mb-5">
                <div class="w-11 h-11 rounded-2xl flex items-center justify-center" style="background: linear-gradient(135deg, var(--color-primary-50), var(--color-primary-100));">
                  <Icon name={card.icon} class="w-5 h-5" style="color: var(--color-primary-600);" />
                </div>
                <h3 class="text-xl md:text-2xl font-bold" style="font-family: var(--font-display); color: var(--color-text-heading);">
                  {card.title}
                </h3>
              </div>
              <p class="text-[15px] leading-[1.75] mb-6" style="color: var(--color-text-body);">
                {card.description}
              </p>
              <ul class="space-y-3">
                {card.points.map((point) => (
                  <li class="flex items-start gap-3 text-[14px]" style="color: var(--color-text-body);">
                    <span class="mt-1 w-5 h-5 rounded-full flex items-center justify-center shrink-0" style="background: var(--color-primary-50);">
                      <svg class="w-3 h-3" viewBox="0 0 16 16" fill="none">
                        <path d="M4 8l3 3 5-5" stroke="var(--color-primary-600)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                    {point}
                  </li>
                ))}
              </ul>
            </div>

            <!-- Screenshot side -->
            <div data-animate={isReversed ? 'slide-left' : 'slide-right'} class={isReversed ? 'md:[direction:ltr]' : ''}>
              {screenshot ? (
                <div class="shadow-screenshot rounded-2xl overflow-hidden" style="border: 1px solid rgba(0,0,0,0.06);">
                  <ScreenshotFrame alt={card.title}>
                    <img src={screenshot} alt={card.title} loading="lazy" class="w-full h-auto" />
                  </ScreenshotFrame>
                </div>
              ) : (
                <div class="aspect-video rounded-2xl flex items-center justify-center shadow-card" style="background: linear-gradient(135deg, var(--color-warm-50), #fff); border: 1px solid var(--color-warm-200);">
                  <Icon name={card.icon} class="w-16 h-16 opacity-10" />
                </div>
              )}
            </div>
          </div>
        );
      })}
    </div>

    <!-- "And also" — polished pill grid -->
    <div data-animate="fade-up" class="max-w-4xl mx-auto">
      <h3 class="text-2xl font-bold text-center mb-10" style="font-family: var(--font-display); color: var(--color-text-heading);">
        {t(lang, 'features.alsoTitle')}
      </h3>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {alsoItems.map((item, i) => (
          <div data-animate="fade-up" style={`--stagger-index: ${i};`} class="flex items-center gap-3 px-5 py-4 rounded-2xl shadow-card transition-all hover:shadow-card-hover" style="background: #fff; border: 1px solid var(--color-warm-200);">
            <div class="w-9 h-9 rounded-xl flex items-center justify-center shrink-0" style="background: var(--color-primary-50);">
              <Icon name={item.icon} class="w-4 h-4" style="color: var(--color-primary-600);" />
            </div>
            <span class="text-[13px] font-semibold" style="color: var(--color-text-heading);">{item.text}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
