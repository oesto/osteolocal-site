---
interface Props {
  variant?: 'primary' | 'secondary' | 'outline';
  size?: 'base' | 'lg';
  href?: string;
  class?: string;
  [key: string]: any;
}

const { variant = 'primary', size = 'base', href, class: className = '', ...rest } = Astro.props;

const baseClasses = 'inline-flex items-center justify-center gap-2 font-semibold rounded-xl transition-all duration-200 cursor-pointer';
const sizeClasses = size === 'lg' ? 'px-8 py-4 text-base' : 'px-6 py-3 text-sm';

const variantStyles: Record<string, string> = {
  primary: 'background: var(--color-primary-600); color: #fff; box-shadow: 0 2px 8px rgba(13,148,136,0.25);',
  secondary: 'background: transparent; color: var(--color-primary-700); border: none;',
  outline: 'background: transparent; color: var(--color-primary-700); border: 2px solid var(--color-primary-500);',
};

const hoverClass = variant === 'primary' ? 'hover:opacity-90 hover:shadow-lg' : variant === 'outline' ? 'hover:bg-primary-50' : 'hover:opacity-70';

const Tag = href ? 'a' : 'button';
---

{href ? (
  <a href={href} class:list={[baseClasses, sizeClasses, hoverClass, className]} style={variantStyles[variant]} {...rest}>
    <slot />
  </a>
) : (
  <button class:list={[baseClasses, sizeClasses, hoverClass, className]} style={variantStyles[variant]} {...rest}>
    <slot />
  </button>
)}
