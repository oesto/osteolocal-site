---
interface Props {
  title: string;
  accent?: string;
  subtitle?: string;
  dark?: boolean;
  class?: string;
}

const { title, accent, subtitle, dark = false, class: className = '' } = Astro.props;
---

<div class:list={['text-center max-w-3xl mx-auto mb-12', className]}>
  <h2
    class="text-[28px] md:text-[40px] font-semibold leading-tight"
    style={`font-family: var(--font-display); color: ${dark ? 'var(--color-text-on-dark)' : 'var(--color-text-heading)'};`}
  >
    {title}
    {accent && <span style="color: var(--color-primary-500);"> {accent}</span>}
  </h2>
  {subtitle && (
    <p class="mt-4 text-base md:text-lg leading-relaxed" style={`color: ${dark ? '#a1a1aa' : 'var(--color-text-muted)'};`}>
      {subtitle}
    </p>
  )}
</div>
