---
import { t } from '../utils/i18n';

interface Props {
  lang: 'fr' | 'en';
}

const { lang } = Astro.props;
---

<div class="fixed bottom-0 left-0 right-0 z-50 md:hidden bg-white/95 backdrop-blur-xl shadow-[0_-4px_20px_rgba(0,0,0,0.08)]" style="border-top: 1px solid rgba(0,0,0,0.06);">
  <div class="px-4 py-3 flex items-center justify-between gap-3">
    <div class="min-w-0">
      <p class="text-xs font-bold truncate" style="color: var(--color-text-heading);">OsteoLocal</p>
      <p class="text-[11px] truncate" style="color: var(--color-primary-600);">
        {lang === 'fr' ? 'Essai gratuit 3 mois' : '3-month free trial'}
      </p>
    </div>
    <a href="#tarifs" class="btn-primary shrink-0 px-5 py-2.5 rounded-xl text-sm font-semibold">
      {t(lang, 'nav.cta')}
    </a>
  </div>
</div>
